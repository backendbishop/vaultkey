# Required. Minimum 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Optional. Defaults to 3001.
PORT=3001

# Optional. Defaults to ./data/vaultkey.db. Use :memory: for an
# ephemeral, non-persistent database (useful for testing).
DB_PATH=./data/vaultkey.db
